pipeline{

agent  any

triggers {
    githubPush()
}

environment{
    Docker_Image = "myapp:latest"
}

stages{





stage('BuildImage'){

    steps{
     bat 'docker build -t %Docker_Image%  project/'
    }
   
}

stage('DeployWithAnsible'){
    steps{
        bat 'docker run --rm -v %cd%:/app -w /app williamyeh/ansible ansible-playbook -i ansible/inventory ansible/deploy.yml'
    }
}



}

post{
    success{
        echo 'Successfully Deployed!'
    }
    failure{
        echo 'Deplyment failed!'
    }
}



}